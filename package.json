{
  "name": "archivolt",
  "version": "0.8.0",
  "description": "ER Model 視覺化標註工具 — 協助老舊專案建構資料關聯",
  "type": "module",
  "bin": {
    "archivolt": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "README.zh-TW.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --format esm --target bun --banner '#!/usr/bin/env bun'",
    "start": "bun dist/index.js",
    "test": "bun test src test",
    "test:watch": "bun test --watch src test",
    "test:coverage": "bun test --coverage src test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src test",
    "lint:fix": "biome lint src test --fix",
    "format": "biome format src test --write",
    "check": "bun run typecheck && bun run lint && bun run test",
    "dev:web": "cd web && bun run dev",
    "dev:all": "bun run dev & cd web && bun run dev",
    "build:ext": "cd extension && bun run build.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@gravito/core": "^2.0.0",
    "csv-parse": "^6.2.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0"
  },
  "overrides": {
    "@gravito/photon": "1.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/pg": "^8.20.0",
    "biome": "latest",
    "bun-types": "latest",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
